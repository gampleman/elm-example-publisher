{
  "name": "elm-example-publisher",
  "version": "2.0.2",
  "type": "module",
  "bin": "dist/cli.js",
  "description": "Create a beautiful example website for your Elm program examples",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gampleman/elm-example-publisher.git"
  },
  "keywords": [
    "elm"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "author": "Jakub Hampl <kopomir@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gampleman/elm-example-publisher/issues"
  },
  "homepage": "https://github.com/gampleman/elm-example-publisher#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "highlight.js": "^11.11.1",
    "html-minifier-terser": "^7.2.0",
    "jsdom": "^29.1.1",
    "node-elm-compiler": "^5.0.6",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.0"
  },
  "peerDependencies": {
    "elm": "^0.19.1-3"
  },
  "devDependencies": {
    "@types/html-minifier-terser": "^7.0.2",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.0.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.0"
  },
  "overrides": {
    "cross-spawn": "^7.0.6"
  }
}
